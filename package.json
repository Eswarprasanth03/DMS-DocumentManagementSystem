{
  "name": "flowsphere-dms",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "FlowSphere DMS — standalone Document Management System frontend",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "setup": "npm install && npm --prefix server install",
    "server": "npm --prefix server start",
    "server:dev": "npm --prefix server run dev",
    "server:seed": "npm --prefix server run seed",
    "samples": "node tools/make-sample-pdfs.mjs",
    "dev:all": "concurrently -n web,api -c magenta,green \"npm run dev\" \"npm run server:dev\""
  },
  "dependencies": {
    "mammoth": "^1.12.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.0",
    "vite": "^6.3.0"
  }
}
