# FlowSphere DMS — backend environment variables
# Copy this file to `.env` (in the server/ folder) and edit as needed.
# Everything has a sensible default, so the app runs WITHOUT a .env file.

# --- Server ---------------------------------------------------------------
# Port the API listens on
PORT=4000

# Secret used to sign JWTs. CHANGE THIS in production.
JWT_SECRET=flowsphere-dms-dev-secret-change-in-prod

# --- Database -------------------------------------------------------------
# 'json'  = local file at server/data/db.json (default, zero-config)
# 'mongo' = MongoDB (local mongod or MongoDB Atlas)
DB_DRIVER=json
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=flowsphere_dms

# Redis for BullMQ background workers (Phase 2)
REDIS_URL=redis://127.0.0.1:6379

# --- OCR pipeline ---------------------------------------------------------
# digital PDFs -> pdf-parse; scanned PDFs/images -> Vision LLM OCR (NVIDIA omni)
# OCR_VISION: 'auto' (use NVIDIA vision when NVIDIA_API_KEY set) | 'off'
OCR_VISION=auto
# OCR_ENGINE: 'tesseract' enables an offline Tesseract fallback | 'auto'
OCR_ENGINE=auto
OCR_MAX_PAGES=5

# --- LLM classifier -------------------------------------------------------
# Provider: 'gemini' | 'nvidia' | 'none' (deterministic local classifier).
LLM_PROVIDER=none

# Google Gemini (a key works only with models your account exposes — list at
# https://generativelanguage.googleapis.com/v1beta/models?key=YOUR_KEY )
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# NVIDIA NIM (OpenAI-compatible)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# --- Email ingestion (IMAP) ----------------------------------------------
# Poll a real mailbox and auto-ingest attachments/bodies via the pipeline.
# For Gmail: enable 2-Step Verification, then create an App Password and use
# it as IMAP_PASSWORD (your normal account password will not work).
IMAP_ENABLED=false
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_POLL_SECONDS=60
IMAP_MARK_SEEN=true
# Optional sender allow-list (comma-separated). Empty = accept from anyone.
IMAP_ALLOWED_SENDERS=
